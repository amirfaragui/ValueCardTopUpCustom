
@(Html.Kendo().Grid<ValueCards.Models.ValueCardModel>()
      .Name("grid")
      .Columns(columns =>
      {
        columns.Bound(model => model.EPAN).Width(100);
        columns.Bound(model => model.Device).Width(80);
        columns.Bound(model => model.Company).Width(120);
        columns.Bound(model => model.Participant).Width(120);
          columns.Bound(model => model.Amount).Width(100);
        //columns.Bound(model => model.Amount).Width(100).Format("{0:C}");
        //columns.Bound(model => model.ValidUntil).Width(150);

      //  columns.Command(command =>
      //  {
        //  command.Custom("Topup").Text("Topup").Click("onTopUp");
        //}).Width(200);

      })
 .ToolBar(t =>
{
    // Add the Custom Upload Button
    t.Custom()
        .Text("Upload Excel")
        .IconClass("k-icon k-i-excel")
        .HtmlAttributes(new { id = "btnUpload", onclick = "openFileDialog(event)" });

    
    t.Search();
})
  .Pageable(p =>
  {
    p.Refresh(true);
    p.PageSizes(new int[] { 50, 100, 200 });
  })
  .Scrollable(scrollable => scrollable.Enabled(true).Height("calc(100vh - 230px)").Virtual(true))
  .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
  .DataSource(datasource => datasource
    .Ajax()
    .Model(model =>
    {
      model.Id(o => o.EPAN);
    })
   // .Read(read => read.Action("read", "consumers"))
    .PageSize(50)
  )
  .Resizable(resize => resize.Columns(true))
  .Sortable()
  .Search(search =>
  {
    search.Field(i => i.EPAN).Field(i => i.Participant);
  })
)
<input type="file" id="excelUpload" style="display: none;" accept=".xlsx, .xls, .csv" onchange="onFileSelected(this)" />

@section Scripts{ 
  <script type="text/javascript">
      function onTopUp(e) {
      e.preventDefault();

      var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
      var url = '@Url.Action("topup", "consumers")/' + dataItem.Id;
      newTab = window.open(url, '_blank');
    }
     function openFileDialog(e) {
            e.preventDefault();
            $("#excelUpload").click();
        }

             function onFileSelected(input) {
            if (input.files && input.files[0]) {
                var formData = new FormData();
                formData.append("file", input.files[0]);

                $.ajax({
                    url: '@Url.Action("UploadExcel", "consumers")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(result) {
                        if (result.success) {
                            var grid = $("#grid").data("kendoGrid");

                            // Option A: Replace all current data with the CSV data
                            grid.dataSource.data(result.data);

                            // Option B: If you want to APPEND to existing data:
                            /*
                            result.data.forEach(function(item) {
                                grid.dataSource.add(item);
                            });
                            */

                            alert("Imported " + result.data.length + " records.");
                        } else {
                            alert(result.message);
                        }
                    },
                    error: function() {
                        alert("Upload failed.");
                    }
                });
                $(input).val(''); // Clear the input
            }
        }



  </script>
}
